# Family Budget Planner — environment template
# Copy this file to `.env` and fill in real values.
# DO NOT commit `.env` to git.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database — MySQL 8 running locally on 3306
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Use `mysql://root@localhost:3306/viyana_budget` if root has no password.
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://root@localhost:3306/viyana_budget

# -----------------------------------------------------------------------------
# Family auth (Wave 1) — both REQUIRED, server will refuse to start without them
# -----------------------------------------------------------------------------

# Generate via:  pnpm tsx scripts/hash-family-password.ts <plaintextPassword>
# Output is a 64-char hex HMAC-SHA256. Paste it below.
FAMILY_PASSWORD_HASH=

# Generate via:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters. Treat as secret.
FAMILY_COOKIE_SECRET=

# -----------------------------------------------------------------------------
# Rate limiting (Wave 2) — optional, defaults are sane
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=200
# LOGIN_RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# Legacy / unused — these are leftover from the Manus template, server boots
# without them. Do NOT set them; the dead-code paths must remain dead.
# -----------------------------------------------------------------------------
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
# JWT_SECRET=
